# Supabase project credentials — copy this file to .env.local and fill in.
# Find these in your Supabase dashboard under Project Settings → API.
#
# When these are NOT set, the app runs in demo mode: all content works from
# bundled seed data, and progress/schedules persist in the browser
# (localStorage guest mode) instead of Supabase.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
